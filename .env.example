# m2c_pipeline environment template
#
# 使用方式：
# 1. 复制为 .env: cp .env.example .env
# 2. 修改下面的占位值
# 3. 直接运行项目即可；m2c_pipeline 会自动加载 .env
#
# 本项目只允许使用 Vertex AI API。
# 不要使用 Google AI Studio / Gemini Developer API 的 API key。
# 不要配置 GOOGLE_API_KEY / GEMINI_API_KEY。
#
# 推荐方式：在 .env 中显式指定 ADC JSON 路径
#   GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/adc-or-service-account.json
#
# 如果未设置 GOOGLE_APPLICATION_CREDENTIALS，
# Google SDK 会回退到系统 ADC：
# - 本机 `gcloud auth application-default login` 生成的 ADC
# - 云上运行环境附加的服务账号 ADC

# === m2c_pipeline config ===

# 必填：Vertex AI project id
M2C_PROJECT_ID=your-gcp-project-id

# 可选：显式指定 ADC JSON 文件路径
# 如果留空，运行时回退到系统 ADC
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/adc-or-service-account.json

# Gemini 文本调用区域
M2C_LOCATION=us-central1

# Gemini 文本模型
M2C_GEMINI_MODEL=gemini-2.0-flash

# Gemini 图片生成模型
M2C_IMAGE_MODEL=gemini-3.1-flash-image-preview

# 默认宽高比
# 有效值: 1:1, 2:3, 3:2, 3:4, 4:3, 4:5, 5:4, 9:16, 16:9, 21:9
M2C_ASPECT_RATIO=1:1

# 图片输出目录
M2C_OUTPUT_DIR=./output

# 当前唯一模板
M2C_TEMPLATE=chiikawa

# 翻译模式
# 可选值: vertex, fallback
# fallback 仅用于 --dry-run 的离线提示词验证
M2C_TRANSLATION_MODE=vertex

# 并发数
M2C_MAX_WORKERS=2

# 单次请求超时（秒）
M2C_REQUEST_TIMEOUT=600

# 重试配置
M2C_MAX_RETRIES=5
M2C_RETRY_MIN_WAIT=2
M2C_RETRY_MAX_WAIT=60

# 日志级别
# 可选值: DEBUG, INFO, WARNING, ERROR
M2C_LOG_LEVEL=INFO
